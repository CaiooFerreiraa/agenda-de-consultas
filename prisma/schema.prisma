generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  password      String?
  image         String?
  role          Role      @default(PATIENT)
  specialty     String?   @db.VarChar(100)
  crm           String?   @db.VarChar(50)
  bio           String?   @db.Text
  formation     String?   @db.Text
  experience    Int?      @default(0)
  lastSeen      DateTime? @map("last_seen")
  price         Decimal?  @db.Decimal(10, 2)
  
  accounts      Account[]
  sessions      Session[]
  
  patientAppointments Appointment[] @relation("PatientAppointments")
  doctorAppointments  Appointment[] @relation("DoctorAppointments")
  
  doctorTimeSlots     TimeSlot[]    @relation("DoctorTimeSlots")
  services            Service[]     @relation("DoctorServices")
  
  reviewsRaw          Review[]      @relation("DoctorReviews")
  givenReviews        Review[]      @relation("PatientReviews")

  @@map("users")
}

model Review {
  id            String   @id @default(cuid())
  appointmentId String   @unique @map("appointment_id")
  patientId     String   @map("patient_id")
  doctorId      String   @map("doctor_id")
  rating        Int      @default(5)
  comment       String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient       User        @relation("PatientReviews", fields: [patientId], references: [id])
  doctor        User        @relation("DoctorReviews", fields: [doctorId], references: [id])

  @@map("reviews")
}

model Service {
  id          String   @id @default(cuid())
  doctorId    String   @map("doctor_id")
  name        String   @db.VarChar(100)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  duration    Int?     // Duração em minutos
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  doctor      User     @relation("DoctorServices", fields: [doctorId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("services")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model TimeSlot {
  id        String   @id @default(cuid())
  doctorId  String   @map("doctor_id")
  date      DateTime
  isBlocked Boolean  @default(false)
  isBooked  Boolean  @default(false)
  
  doctor    User     @relation("DoctorTimeSlots", fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment?

  @@map("time_slots")
}

model Appointment {
  id          String   @id @default(cuid())
  patientId   String   @map("patient_id")
  doctorId    String   @map("doctor_id")
  timeSlotId  String   @unique @map("time_slot_id")
  status      AppointmentStatus @default(SCHEDULED)
  notes       String?  @db.Text
  serviceId   String?  @map("service_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  patient     User     @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor      User     @relation("DoctorAppointments", fields: [doctorId], references: [id])
  timeSlot    TimeSlot @relation(fields: [timeSlotId], references: [id])
  review      Review?
  service     Service? @relation(fields: [serviceId], references: [id])

  @@map("appointments")
}

model Message {
  id          String   @id @default(cuid())
  content     String   @db.Text
  senderId    String   @map("sender_id")
  receiverId  String   @map("receiver_id")
  chatId      String?  @map("chat_id")
  createdAt   DateTime @default(now()) @map("created_at")
  isRead      Boolean  @default(false) @map("is_read")

  chat        Chat?    @relation(fields: [chatId], references: [id], onDelete: SetNull)

  @@map("messages")
}

model Chat {
  id          String   @id @default(cuid())
  patientId   String   @map("patient_id")
  doctorId    String   @map("doctor_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  messages    Message[]

  @@unique([patientId, doctorId])
  @@map("chats")
}
